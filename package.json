{
  "name": "ce-broker-automation",
  "version": "1.0.0",
  "description": "Playwright automation for CE Broker CEU status scraping and Excel export",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "serve": "node server.js",
    "build": "echo Dashboard pre-built",
