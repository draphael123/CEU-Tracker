    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "playwright": "^1.41.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "xlsx": "^0.18.5"
  }
